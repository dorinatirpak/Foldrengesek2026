@model Book
@{ ViewData["Title"] = "Uj konyv felvetele"; }

<div class="page-header">
    <h1>Uj konyv felvetele</h1>
    <a asp-action="Index" class="btn btn-outline">&larr; Vissza</a>
</div>

<div class="section-card form-card">
    <form asp-action="Create" method="post">
        <div class="form-grid">
            <div class="form-group">
                <label>Szerzo *</label>
                <input asp-for="Author" class="form-control" required />
            </div>
            <div class="form-group">
                <label>Cim *</label>
                <input asp-for="Title" class="form-control" required />
            </div>
            <div class="form-group">
                <label>Kiado</label>
                <input asp-for="Publisher" class="form-control" />
            </div>
            <div class="form-group">
                <label>Kiadasi ev</label>
                <input asp-for="Year" type="number" class="form-control" min="1000" max="2100" />
            </div>
            <div class="form-group">
                <label>Kiadas</label>
                <input asp-for="Edition" class="form-control" placeholder="pl. 3rd" />
            </div>
            <div class="form-group">
                <label>ISBN</label>
                <input asp-for="ISBN" class="form-control" placeholder="978-..." />
            </div>
            <div class="form-group">
                <label>Peldanyszam</label>
                <input asp-for="CopyCount" type="number" class="form-control" min="1" value="1" />
            </div>
            <div class="form-group form-group--checkbox">
                <label>
                    <input asp-for="IsLoanable" type="checkbox" checked />
                    Kolcsonozheto
                </label>
            </div>
        </div>
        <div class="form-actions">
            <button type="submit" class="btn btn-primary">Mentes</button>
            <a asp-action="Index" class="btn btn-outline">Megse</a>
        </div>
    </form>
</div>
