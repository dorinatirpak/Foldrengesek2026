@model IEnumerable<Földrengések2026.ViewModels.Feladat3ViewModel>

@{
    ViewData["Title"] = "3. feladat";
}

<h1>Vármegyei feljegyzett földrengések darabszáma</h1>

<ul class="list-group mt-3 mb-3">
    @foreach (var item in Model)
    {
        <li class="list-group-item d-flex justify-content-between align-items-center">
            @item.Varmegye
            <span class="badge bg-primary rounded-pill">@item.Count db</span>
        </li>
    }
</ul>

<p>
    <a asp-action="Index" class="btn btn-secondary">Vissza a feladatokhoz</a>
</p>